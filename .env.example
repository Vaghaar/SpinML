# ─────────────────────────────────────────────────────────────────────────────
#  SpinMyLunch — Variables d'environnement
#  Copiez ce fichier en .env et remplissez toutes les valeurs.
#  NE JAMAIS committer le fichier .env (il est dans .gitignore).
# ─────────────────────────────────────────────────────────────────────────────

# ─── Base de données PostgreSQL ───────────────────────────────────────────────
POSTGRES_DB=spinmylunch
POSTGRES_USER=spinmylunch
# Générer : openssl rand -base64 32
POSTGRES_PASSWORD=change_me_strong_password

# ─── Redis ────────────────────────────────────────────────────────────────────
# Générer : openssl rand -base64 32
REDIS_PASSWORD=change_me_strong_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
# OBLIGATOIRE en production — minimum 256 bits
# Générer : openssl rand -base64 64
JWT_SECRET=change_me_generate_with_openssl_rand_base64_64

# ─── Google OAuth 2.0 ─────────────────────────────────────────────────────────
# Console : https://console.cloud.google.com/ -> APIs -> Credentials -> OAuth 2.0
# Redirect URI autorisee : ${FRONTEND_URL}/auth/callback
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-your_client_secret

# ─── URLs ─────────────────────────────────────────────────────────────────────
# Developpement local :
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_WS_URL=ws://localhost:8080
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# Production (exemple) :
# FRONTEND_URL=https://spinmylunch.example.com
# NEXT_PUBLIC_API_URL=https://api.spinmylunch.example.com
# NEXT_PUBLIC_WS_URL=wss://api.spinmylunch.example.com
# NEXT_PUBLIC_GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com

# ─── Spring Boot ──────────────────────────────────────────────────────────────
# dev | prod
SPRING_PROFILES_ACTIVE=prod
